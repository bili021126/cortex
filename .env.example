# Cortex 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# DeepSeek API 密钥（必填）
DEEPSEEK_API_KEY=sk-your-key-here

# API 基础 URL
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 对话模型（自审视/圆桌会议场景使用 deepseek-reasoner 思考模式）
DEEPSEEK_CHAT_MODEL=deepseek-reasoner

# 推理模型（MetaAgent 顶层规划使用 deepseek-v4-pro）
DEEPSEEK_REASONER_MODEL=deepseek-v4-pro
